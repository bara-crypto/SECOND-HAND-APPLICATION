{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",

  "projects": {
    "Project-2": {
      "projectType": "application",
      "schematics": {},
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "src/main.ts",
            "polyfills": [
              "zone.js"
            ],
            "tsConfig": "tsconfig.app.json",
            "assets": [
              "src/assets",
              {
                "glob": "**/*",
                "input": "public"
              }
            ],
            "styles": [
              "src/styles.css",
              "src/assets/css/vendor.css",

              "node_modules/bootstrap/dist/css/bootstrap.min.css",
              "node_modules/@ng-select/ng-select/themes/default.theme.css",
              "node_modules/ngx-owl-carousel-o/lib/styles/prebuilt-themes/owl.carousel.min.css",
              "node_modules/ngx-owl-carousel-o/lib/styles/prebuilt-themes/owl.theme.default.min.css",

              "src/assets/aranoz-css/bootstrap.min.css", 
              "src/assets/aranoz-css/animate.css", 
              "src/assets/aranoz-css/owl.carousel.min.css", 
              "src/assets/aranoz-css/nice-select.css", 
              "src/assets/aranoz-css/all.css", 
              "src/assets/aranoz-css/flaticon.css", 
              "src/assets/aranoz-css/themify-icons.css", 
              "src/assets/aranoz-css/magnific-popup.css", 
              "src/assets/aranoz-css/slick.css", 
              "src/assets/aranoz-css/price_rangs.css", 
              "src/assets/aranoz-css/style.css",


              "src/assets/aranoz-css/lightslider.min.css",
              "src/assets/aranoz-css/swiper.min.css",
              "src/assets/aranoz-css/lightslider.min.css"
            ],

            
            "scripts": [

              "node_modules/jquery/dist/jquery.min.js", 
              "src/assets/aranoz-js/lightslider.min.js",
              "src/assets/aranoz-js/theme.js",


              "node_modules/bootstrap/dist/js/bootstrap.min.js",
              "node_modules/jquery/dist/jquery.min.js",
              "src/assets/js/jquery-1.11.0.min.js",
              "src/assets/js/swiper-bundle.min.js",
              "src/assets/js/bootstrap.bundle.min.js",
              "src/assets/js/plugins.js",
              "src/assets/js/script.js",


              "src/assets/aranoz-js/jquery-1.12.1.min.js", 
              "src/assets/aranoz-js/popper.min.js", 
              "src/assets/aranoz-js/bootstrap.min.js", 
              "src/assets/aranoz-js/jquery.magnific-popup.js", 
              "src/assets/aranoz-js/swiper.min.js", 
              "src/assets/aranoz-js/masonry.pkgd.js", 
              "src/assets/aranoz-js/owl.carousel.min.js", 
              "src/assets/aranoz-js/jquery.nice-select.min.js", 
              "src/assets/aranoz-js/slick.min.js", 
              "src/assets/aranoz-js/jquery.counterup.min.js", 
              "src/assets/aranoz-js/waypoints.min.js", 
              "src/assets/aranoz-js/contact.js", 
              "src/assets/aranoz-js/jquery.ajaxchimp.min.js", 
              "src/assets/aranoz-js/jquery.form.js", 
              "src/assets/aranoz-js/jquery.validate.min.js", 
              "src/assets/aranoz-js/mail-script.js", 
              "src/assets/aranoz-js/stellar.js",
               "src/assets/aranoz-js/price_rangs.js", 
               "src/assets/aranoz-js/custom.js",


               "src/assets/aranoz-js/swiper.jquery.js",
               "src/assets/aranoz-js/lightslider.min.js",
               "src/assets/aranoz-js/theme.js"

            ]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "Project-2:build:production"
            },
            "development": {
              "buildTarget": "Project-2:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "extract-i18n": {
          "builder": "@angular/build:extract-i18n"
        },
        "test": {
          "builder": "@angular/build:karma",
          "options": {
            "polyfills": [
              "zone.js",
              "zone.js/testing"
            ],
            "tsConfig": "tsconfig.spec.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "public"
              }
            ],
            "styles": [
              "src/styles.css"
            ]
          }
        }
      }
    }
  },
  "cli": {
    "analytics": false
  }
}
